# ============================================================================
# CAPSTONE PROJECT - BACKEND ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in actual values for your environment
# DO NOT commit .env file - it contains sensitive credentials
# ============================================================================

# ============================================================================
# LOCAL DEVELOPMENT - DATABASE CONFIGURATION
# ============================================================================
# Use these settings for local development with XAMPP MySQL
# The script auto-detects local mode when MYSQL_URL is not set

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=capstone_db
DB_PORT=3306

# ============================================================================
# RAILWAY PRODUCTION - DATABASE CONFIGURATION
# ============================================================================
# For Railway deployments, set MYSQL_URL environment variable
# Format: mysql://username:password@host:port/database
# 
# Steps to get Railway MySQL URL:
# 1. Go to https://railway.app
# 2. Open your project → MySQL plugin
# 3. Click "Connect" or look for connection details
# 4. Copy the full connection string
#
# Example (do NOT use this - replace with your actual Railway URL):
# MYSQL_URL=mysql://root:password@containers-us-west-xx.railway.app:3306/railway
#
# In Railway dashboard environment variables section, paste:
# MYSQL_URL=mysql://root:your_actual_password@containers-us-west-xx.railway.app:3306/railway

# MYSQL_URL=your_railway_mysql_connection_string_here

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Node environment
NODE_ENV=development

# Server port
PORT=5000

# JWT Secret for token signing
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Production: Use a long, random, secure string
JWT_SECRET=k8Xp2sQ9vLmN7jR4wT6yB3cF0hA5dE1

# JWT Expiry (milliseconds - default: 8 hours = 28800000)
JWT_EXPIRY=28800000

# Bcrypt salt rounds for password hashing (default: 12)
BCRYPT_ROUNDS=12

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed frontend URLs

# Local development
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Production (update with your actual Vercel domain)
# CORS_ORIGIN=https://peso-juban.vercel.app

# ============================================================================
# ADMIN ACCOUNT CREATION (Optional)
# ============================================================================
# Used by seedAdmin.js script for initial admin seeding
# Only used if running: npm run seed:admin

# ADMIN_EMAIL=pesoadmin@juban.gov.ph
# ADMIN_PASSWORD=SecureAdminPass123!

# ============================================================================
# EMAIL CONFIGURATION (Currently Disabled)
# ============================================================================
# For future email notification features
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-specific-password
# EMAIL_FROM=noreply@peso-juban.gov.ph

# ============================================================================
# SMS CONFIGURATION (Currently Disabled - OTP Removed)
# ============================================================================
# Twilio was previously used for OTP but has been removed from signup flow
# Keeping config for future reference if SMS features are needed
#
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# SECURITY NOTES
# ============================================================================
# 1. NEVER commit .env file to version control
# 2. .env is in .gitignore - do NOT try to commit it
# 3. Use strong JWT_SECRET in production (32+ characters)
# 4. Update CORS_ORIGIN to match your frontend production URL
# 5. In Railway, set environment variables in Dashboard:
#    Settings → Environment → Add Variable → MYSQL_URL (paste connection string)
# 6. For local development, copy this file to .env and fill in DB credentials
# 7. Each deployment environment should have its own .env configuration
#
# ============================================================================
# ADMIN ACCOUNT CREATION - RAILWAY PRODUCTION WORKFLOW
# ============================================================================
# To create admin accounts in Railway production database:
#
# 1. Get Railway MySQL connection string from Dashboard
# 2. In your terminal (Windows PowerShell):
#    $env:MYSQL_URL="mysql://user:pass@host:port/db"
#    npm run create:admin -- --email "admin@test.com" --password "Pass123!"
#
# 3. Script will:
#    - Auto-detect MYSQL_URL environment variable
#    - Connect to Railway database
#    - Create admin account with bcryptjs hashing
#    - Return success message with User ID
#
# 4. Verify in Railway MySQL Dashboard:
#    SELECT * FROM users WHERE role='admin';
#
# ============================================================================
